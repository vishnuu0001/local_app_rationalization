# App Rationalization Platform - Frontend Environment Variables
# For local dev: copy to .env.development.local  (loaded by npm start only)
# For production build: update .env.production    (loaded by npm run build only)

# API Configuration (REQUIRED)
# LOCAL dev:   http://localhost:5000/api
# PRODUCTION:  https://api.stratapp.org/api
REACT_APP_API_URL=https://api.stratapp.org/api
# Production Code Analysis launcher target
# Recommended: https://code.stratapp.org
REACT_APP_CODE_ANALYSIS_URL=https://code.stratapp.org
REACT_APP_ENVIRONMENT=production

# Application Version
REACT_APP_VERSION=1.0.0
