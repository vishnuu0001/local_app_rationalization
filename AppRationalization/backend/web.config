<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <add name="Python FastCGI"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="__BACKEND_PYTHON__|__BACKEND_WFASTCGI__"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <rewrite>
      <outboundRules>
        <rule name="CORS Allow stratapp.org" preCondition="CORSFromStratapp" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern="^$" />
          <action type="Rewrite" value="https://stratapp.org" />
        </rule>
        <rule name="CORS Allow www.stratapp.org" preCondition="CORSFromWwwStratapp" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern="^$" />
          <action type="Rewrite" value="https://www.stratapp.org" />
        </rule>
        <rule name="CORS Allow localhost:3000" preCondition="CORSFromLocalhost3000" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern="^$" />
          <action type="Rewrite" value="http://localhost:3000" />
        </rule>
        <rule name="CORS Allow localhost:3001" preCondition="CORSFromLocalhost3001" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern="^$" />
          <action type="Rewrite" value="http://localhost:3001" />
        </rule>
        <rule name="CORS Vary Header" preCondition="CORSAnyAllowed" stopProcessing="false">
          <match serverVariable="RESPONSE_Vary" pattern=".*" />
          <action type="Rewrite" value="Origin" />
        </rule>
        <preConditions>
          <preCondition name="CORSFromStratapp">
            <add input="{HTTP_ORIGIN}" pattern="^https://stratapp\.org$" />
          </preCondition>
          <preCondition name="CORSFromWwwStratapp">
            <add input="{HTTP_ORIGIN}" pattern="^https://www\.stratapp\.org$" />
          </preCondition>
          <preCondition name="CORSFromLocalhost3000">
            <add input="{HTTP_ORIGIN}" pattern="^http://localhost:3000$" />
          </preCondition>
          <preCondition name="CORSFromLocalhost3001">
            <add input="{HTTP_ORIGIN}" pattern="^http://localhost:3001$" />
          </preCondition>
          <preCondition name="CORSAnyAllowed">
            <add input="{HTTP_ORIGIN}" pattern="^https?://(stratapp\.org|www\.stratapp\.org|localhost:\d+|127\.0\.0\.1:\d+)$" />
          </preCondition>
        </preConditions>
      </outboundRules>
    </rewrite>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>
