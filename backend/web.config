<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <handlers>
      <!-- Route ALL verbs (including OPTIONS preflight) through Flask via wfastcgi -->
      <add name="Python FastCGI"
           path="*"
           verb="*"
           modules="FastCgiModule"
           scriptProcessor="E:\techmaapprationalization\local_app_rationalization\backend\.venv\Scripts\python.exe|E:\techmaapprationalization\local_app_rationalization\backend\wfastcgi_runner.py"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <fastCgi>
      <!--
        Set all required env vars at the FastCGI process level.
        These are injected before any Python code runs, so they are
        guaranteed to reach Flask regardless of .env loading.
      -->
      <application
        fullPath="E:\techmaapprationalization\local_app_rationalization\backend\.venv\Scripts\python.exe"
        arguments="E:\techmaapprationalization\local_app_rationalization\backend\wfastcgi_runner.py"
        instanceMaxRequests="10000"
        maxInstances="4"
        idleTimeout="300"
        activityTimeout="300"
        requestTimeout="300">
        <environmentVariables>
          <environmentVariable name="WSGI_HANDLER"                  value="run.app" />
          <environmentVariable name="PYTHONPATH"                     value="E:\techmaapprationalization\local_app_rationalization\backend" />
          <environmentVariable name="FLASK_ENV"                      value="production" />
          <environmentVariable name="FLASK_DEBUG"                    value="false" />
          <environmentVariable name="DATABASE_PROVIDER"              value="sqlite" />
          <environmentVariable name="DATABASE_PATH"                  value="E:\techmaapprationalization\local_app_rationalization\backend\instance\infra_assessment.db" />
          <environmentVariable name="SECRET_KEY"                     value="Zxcvbnm@0806@1973" />
          <environmentVariable name="CORS_ORIGINS"                   value="https://stratapp.org,https://www.stratapp.org,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001" />
          <environmentVariable name="INCLUDE_LOCALHOST_CORS_ORIGINS" value="true" />
          <environmentVariable name="UPLOAD_FOLDER"                  value="E:\techmaapprationalization\local_app_rationalization\backend\uploads" />
          <environmentVariable name="MAX_CONTENT_LENGTH"             value="52428800" />
        </environmentVariables>
      </application>
    </fastCgi>

    <!--
      IIS URL Rewrite outbound rules — belt-and-suspenders CORS headers.
      Flask-CORS sets these dynamically; IIS adds them as a fallback so
      the browser never sees a response without Access-Control-Allow-Origin
      when the request came from stratapp.org or localhost.

      Requires: IIS URL Rewrite Module 2.x
    -->
    <rewrite>
      <outboundRules>

        <rule name="CORS Allow stratapp.org" preCondition="CORSFromStratapp" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern=".*" />
          <action type="Rewrite" value="https://stratapp.org" />
        </rule>

        <rule name="CORS Allow www.stratapp.org" preCondition="CORSFromWwwStratapp" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern=".*" />
          <action type="Rewrite" value="https://www.stratapp.org" />
        </rule>

        <rule name="CORS Allow localhost:3000" preCondition="CORSFromLocalhost3000" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern=".*" />
          <action type="Rewrite" value="http://localhost:3000" />
        </rule>

        <rule name="CORS Allow localhost:3001" preCondition="CORSFromLocalhost3001" stopProcessing="false">
          <match serverVariable="RESPONSE_Access_Control_Allow_Origin" pattern=".*" />
          <action type="Rewrite" value="http://localhost:3001" />
        </rule>

        <rule name="CORS Vary Header" preCondition="CORSAnyAllowed" stopProcessing="false">
          <match serverVariable="RESPONSE_Vary" pattern=".*" />
          <action type="Rewrite" value="Origin" />
        </rule>

        <preConditions>
          <preCondition name="CORSFromStratapp">
            <add input="{HTTP_ORIGIN}" pattern="^https://stratapp\.org$" />
          </preCondition>
          <preCondition name="CORSFromWwwStratapp">
            <add input="{HTTP_ORIGIN}" pattern="^https://www\.stratapp\.org$" />
          </preCondition>
          <preCondition name="CORSFromLocalhost3000">
            <add input="{HTTP_ORIGIN}" pattern="^http://localhost:3000$" />
          </preCondition>
          <preCondition name="CORSFromLocalhost3001">
            <add input="{HTTP_ORIGIN}" pattern="^http://localhost:3001$" />
          </preCondition>
          <preCondition name="CORSAnyAllowed">
            <add input="{HTTP_ORIGIN}" pattern="^https?://(stratapp\.org|www\.stratapp\.org|localhost:\d+|127\.0\.0\.1:\d+)$" />
          </preCondition>
        </preConditions>

      </outboundRules>
    </rewrite>

    <!--
      Security / cache headers for API responses.
      Do NOT add Access-Control-Allow-Origin here as a static customHeader —
      that would collide with the dynamic values set by Flask-CORS.
    -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options"        value="DENY" />
      </customHeaders>
    </httpProtocol>

  </system.webServer>
</configuration>

