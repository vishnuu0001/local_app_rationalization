<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="FlaskFastCGI" 
           path="*" 
           verb="*" 
           modules="FastCGIModule" 
           scriptProcessor="C:\app-rationalization\backend\venv\Scripts\python.exe|wfastcgi.py" 
           resourceType="Unspecified" 
           requireAccess="Script" />
    </handlers>
    <fastCgi>
      <application fullPath="C:\app-rationalization\backend\venv\Scripts\python.exe|wfastcgi.py" 
                   arguments="run:app" 
                   maxInstances="4">
        <environmentVariables>
          <environmentVariable name="PYTHONPATH" value="C:\app-rationalization\backend" />
          <environmentVariable name="FLASK_ENV" value="production" />
        </environmentVariables>
      </application>
    </fastCgi>
    <rewrite>
      <rules>
        <rule name="Static Files" stopProcessing="true">
          <match url="^/static/" />
          <action type="Rewrite" url="{REQUEST_URI}" />
        </rule>
        <rule name="API Routes" stopProcessing="true">
          <match url="^/api/" />
          <action type="Rewrite" url="{REQUEST_URI}" />
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <fileExtensions>
          <add fileExtension=".db" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
