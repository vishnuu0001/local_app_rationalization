# App Rationalization Platform - Backend Environment Variables
# For local development: Copy to .env and fill in your values
# For Vercel production: Set in Vercel Dashboard - Settings - Environment Variables

# ========== FLASK CONFIGURATION (REQUIRED) ==========
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-very-secure-random-key-min-32-chars-change-in-production
JSON_SORT_KEYS=false

# ========== DATABASE CONFIGURATION (SQLite) ==========
# LOCAL development: ./apprationalization.db
# VERCEL production: sqlite:////tmp/apprationalization.db
DATABASE_URL=sqlite:////tmp/apprationalization.db

# SQLAlchemy Configuration
SQLALCHEMY_ECHO=false
SQLALCHEMY_TRACK_MODIFICATIONS=false

# ========== CORS & SECURITY ==========
# LOCAL DEV + LOCAL IIS: http://localhost:3000, http://localhost:3001
# PUBLIC FRONTEND EXAMPLE: https://stratapp.org
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,https://stratapp.org
# Set to false only if you want strict CORS and no automatic localhost allowances
INCLUDE_LOCALHOST_CORS_ORIGINS=true
ALLOWED_HOSTS=localhost,127.0.0.1,app-rationalization-backend.vercel.app

# ========== FILE UPLOAD CONFIGURATION ==========
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800
MAX_UPLOAD_SIZE=52428800

# ========== API CONFIGURATION ==========
API_TIMEOUT=30

# ========== LOGGING ==========
LOG_LEVEL=INFO
