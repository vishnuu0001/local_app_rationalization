# App Rationalization Platform - Backend Environment Variables
# Copy to .env and fill in your values for IIS deployment

# ========== FLASK CONFIGURATION (REQUIRED) ==========
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-very-secure-random-key-min-32-chars-change-in-production
JSON_SORT_KEYS=false

# ========== DATABASE CONFIGURATION (SQLite) ==========
# SQLite stored in backend/instance/ (created automatically by the app)
DATABASE_PROVIDER=sqlite
# Override storage path (absolute Windows path):
# DATABASE_PATH=E:/path/to/backend/instance/infra_assessment.db

# SQLAlchemy Configuration
SQLALCHEMY_ECHO=false
SQLALCHEMY_TRACK_MODIFICATIONS=false

# ========== CORS & SECURITY ==========
# Add your production frontend domain plus any local dev origins needed
CORS_ORIGINS=https://stratapp.org,https://www.stratapp.org,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Set to false only if you want strict CORS and no automatic localhost allowances
INCLUDE_LOCALHOST_CORS_ORIGINS=true

# ========== FILE UPLOAD CONFIGURATION ==========
# Use an absolute Windows path for IIS deployments
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=52428800

# ========== LOGGING ==========
LOG_LEVEL=INFO

# ========== OLLAMA / LLM CONFIGURATION ==========
# Ollama inference server URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# GPU layers to offload: -1 = ALL layers → full CUDA/GPU mode (recommended).
# Set to 0 for CPU-only inference. Requires NVIDIA drivers + Ollama CUDA build.
OLLAMA_NUM_GPU=-1

# GPU device index (0 = first GPU, e.g. RTX 4070 SUPER).
OLLAMA_MAIN_GPU=0

# ── Recommended model for RTX 4070 SUPER (12 GB VRAM) ──────────────────────
# qwen2.5:14b   → best quality/speed balance (~8.9 GB VRAM Q4_K_M, fits 12 GB)
# mistral:7b    → fastest option (~4.1 GB VRAM, strong instruction following)
# llama3.1:8b   → strong reasoning, long context (~4.9 GB VRAM)
# gemma2:9b     → excellent benchmarks (~5.5 GB VRAM)
# Pull model: ollama pull qwen2.5:14b
OLLAMA_PREFERRED_MODEL=qwen2.5:14b
