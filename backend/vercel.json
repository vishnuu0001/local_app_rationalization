{
  "version": 2,
  "env": {
    "CORS_ORIGINS": "https://stratapp.org,https://www.stratapp.org",
    "INCLUDE_LOCALHOST_CORS_ORIGINS": "false"
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
