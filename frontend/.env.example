# App Rationalization Platform - Frontend Environment Variables
# For local development: Copy to .env.local
# For production: Set in Vercel Dashboard - Settings - Environment Variables

# API Configuration (REQUIRED)
# LOCAL: http://localhost:5000/api
# PRODUCTION: https://your-backend-domain/api OR /api (same-origin reverse proxy)
# IMPORTANT: Do not use localhost in public deployments
REACT_APP_API_URL=https://your-backend-api.vercel.app/api
REACT_APP_ENVIRONMENT=production

# Application Version
REACT_APP_VERSION=1.0.0

# Optional: Analytics/Monitoring
# REACT_APP_SENTRY_DSN=
# REACT_APP_ANALYTICS_ID=
